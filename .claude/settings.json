{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/scripts/hooks/pre-tool-use.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/scripts/hooks/classify-message.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/scripts/hooks/validate-write.ts",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-compact.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session end checklist:\n- Archive completed projects? (work/01_PROJECTS/ → work/07_ARCHIVE/YYYY/)\n- Update indexes? (INDEX.md, Memories.md, PEOPLE.md, WINS.md)\n- New notes linked? (orphans are bugs)\n- Notes still in Inbox? (inbox/raw/ or inbox/ready/ — run /process or /distribute)\n- Domain indexes up to date? (run map-domain if domain work was done)\n- Run /audit if many notes were created/modified'",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
