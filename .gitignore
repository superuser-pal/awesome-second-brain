# Obsidian (runtime state, not vault config)
.obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/*/data.json
.obsidian/graph.json

# OS
.DS_Store
.Trash/

# Claude Code (local settings are personal — generated by install script)
# Edit settings.local.example.json instead; installer injects {{VAULT_PATH}}
.claude/settings.local.json
settings.local.json
.claude/.claudian/

# Private backup (local only)
.private_backup/

# QMD index (local, regenerated)
.qmd/

# Session logs (local transcripts)
thinking/session-logs/

# Local working files — not for the repo
TESTING_PLAN.md
TESTING_PLAN_V2.md
IMPROVEMENTS.md
ONBOARDING.md
docs/ONBOARDING.md
docs/PERSONAL-DATA-SEPARATION.md

# Hook script dependencies (installed via bun install)
.claude/scripts/node_modules/
.claude/scripts/bun.lockb

# Personal vault content — never commit
# We ignore all markdown in these roots to prevent accidental disclosure.
# Structural files like README.md and INDEX.md can be negated.
plan/**/*.md
!plan/.gitkeep

thinking/**/*.md
!thinking/README.md
!thinking/.gitkeep

inbox/**/*.md
!inbox/.gitkeep

work/**/*.md
!work/INDEX.md
!work/.gitkeep

domains/**/*.md
!domains/**/INDEX.md
!domains/**/.gitkeep
V1CLAUDE.md
V2CLAUDE.md

# Exclude specific files that were part of original tracked set but are personal
brain/MASTER_ARCHIVE/

# Session cache and processing queue — personal operational state, not repo-bound
brain/CACHE.md
brain/QUEUE.md
brain/CROSS_PROJECT_REF.md
brain/AUDIT_REPORTS/

# Spec-kit features (internal building plans)
_spec-kit/features/
